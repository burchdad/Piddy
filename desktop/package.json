{
  "name": "piddy",
  "version": "1.0.0",
  "description": "Piddy - AI Backend Developer Agent Desktop Client",
  "main": "main.js",
  "homepage": "./",
  "repository": {
    "type": "git",
    "url": "https://github.com/burchdad/Piddy.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"wait-on http://localhost:3000 && electron .\" \"npm run start-react\"",
    "start-react": "cd ../frontend && npm start",
    "build": "npm run build-react && electron-builder",
    "build-react": "cd ../frontend && npm run build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "author": {
    "name": "Piddy DevOps Team",
    "email": "stephen.burch@ghostai.solutions"
  },
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.4",
    "concurrently": "^8.2.2",
    "wait-on": "^7.1.0",
    "electron-is-dev": "^3.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "fix-path": "^4.0.0"
  },
  "build": {
    "appId": "com.piddy.app",
    "productName": "Piddy",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "node_modules/fix-path/**/*",
      "node_modules/axios/**/*",
      "node_modules/follow-redirects/**/*",
      "node_modules/form-data/**/*",
      "node_modules/proxy-from-env/**/*",
      "node_modules/mime-types/**/*",
      "node_modules/mime-db/**/*",
      "node_modules/asynckit/**/*",
      "node_modules/combined-stream/**/*",
      "node_modules/delayed-stream/**/*"
    ],
    "extraFiles": [
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      },
      {
        "from": "../start_piddy.py",
        "to": "start_piddy.py"
      },
      {
        "from": "../requirements.txt",
        "to": "requirements.txt"
      }
    ],
    "win": {
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": ["sha256"],
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Piddy"
    },
    "mac": {
      "target": ["zip"],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Development"
    }
  }
}
