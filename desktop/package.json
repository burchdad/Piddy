{
  "name": "piddy",
  "version": "1.0.0",
  "description": "Piddy - AI Backend Developer Agent Desktop Client",
  "main": "main.js",
  "homepage": "./",
  "repository": {
    "type": "git",
    "url": "https://github.com/burchdad/Piddy.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "concurrently \"wait-on http://localhost:3000 && electron .\" \"npm run start-react\"",
    "start-react": "cd ../frontend && npm start",
    "build": "npm run build-react && electron-builder",
    "build-react": "cd ../frontend && npm run build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "author": "DevOps Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.1.4",
    "concurrently": "^8.2.2",
    "wait-on": "^7.1.0",
    "electron-is-dev": "^3.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "electron-log": "^5.1.0",
    "fix-path": "^4.0.0"
  },
  "build": {
    "appId": "com.piddy.app",
    "productName": "Piddy",
    "directories": {
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "../frontend/dist/**/*",
      "../requirements.txt",
      "../src/**/*",
      "../config/**/*",
      "../data/**/*",
      "../start_piddy.py"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Piddy"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    }
  }
}
